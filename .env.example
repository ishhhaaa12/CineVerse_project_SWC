# =============================================================================
# CineVerse — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# IMPORTANT: All variables are NEXT_PUBLIC_ prefixed, meaning they are
# embedded into the client-side bundle at build time. Do NOT store
# sensitive secrets here.
# =============================================================================

# -----------------------------------------------------------------------------
# OMDB API — Movie & TV Show Data (REQUIRED)
# -----------------------------------------------------------------------------
# Used by: src/services/movieApi.ts
# Purpose: Fetches movie/TV metadata, search results, and detailed information
# Get your free key at: https://www.omdbapi.com/apikey.aspx
# Free tier: 1,000 requests/day | Paid: up to 100,000/day
# Example: a1b2c3d4
NEXT_PUBLIC_OMDB_API_KEY=your_omdb_api_key_here

# -----------------------------------------------------------------------------
# Google Gemini AI API — AI Chatbot (REQUIRED)
# -----------------------------------------------------------------------------
# Used by: src/services/gemini.ts, src/components/Chatbot.tsx
# Purpose: Powers the AI movie recommendation chatbot (gemini-2.0-flash model)
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/minute, 1 million tokens/minute
# Example: AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# YouTube Data API v3 — Movie Trailers (OPTIONAL)
# -----------------------------------------------------------------------------
# Used by: src/services/trailerApi.ts, src/components/TrailerPlayer.tsx
# Purpose: Searches YouTube for official movie trailers to embed in detail pages
# Get your key at: https://console.cloud.google.com → Enable "YouTube Data API v3"
# Free tier: 10,000 units/day
# Note: If not set, the trailer section will be hidden on movie detail pages
# Example: AIzaSyYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here
